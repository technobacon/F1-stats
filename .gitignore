# Python
__pycache__/
*.py[cod]
.pytest_cache/
.venv/
venv/

# Prototype SQLite database (regenerated by app.seed)
backend/*.db
# Transient SQLite sidecar files (rollback journal / WAL)
backend/*.db-journal
backend/*.db-wal
backend/*.db-shm

# Raw Jolpica API response cache (etl.py); regenerated weekly
backend/.http_cache/

# Litestream binary, fetched at build time (render.yaml) — never committed
backend/bin/

# OS / editor
.DS_Store
*.swp

# Transient ETL build log (scripts/build_and_review, one-off full-history build)
backend/etl_build.log
